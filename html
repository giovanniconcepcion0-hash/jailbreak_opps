<!-- TROLLSTORE -->
<section id="trollstore">
  <div class="section-label">TrollStore</div>
  <div class="section-title">Permanent IPA installs. No jailbreak needed.</div>
  <p class="section-desc">TrollStore uses a CoreTrust bug to permanently sign and install apps with almost any entitlement — no kernel exploit required.</p>

  <div class="trollstore-box">
    <div class="trollstore-header">
      <span class="troll-icon">🧌</span>
      <div class="troll-meta">
        <h3>TrollStore 2</h3>
        <p>Permanent IPA installer via CoreTrust · Not a jailbreak</p>
      </div>
      <a href="https://ios.cfw.guide/installing-trollstore/" target="_blank" class="btn btn-orange">Install Guide ↗</a>
